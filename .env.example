# UPI Fraud MLOps Pro — Environment Configuration
# COPY THIS FILE TO .env AND FILL IN ALL VALUES BEFORE RUNNING
# ⚠️ NEVER commit .env to version control

# ─── REQUIRED: Generate secure values before any deployment ───────────────────

# JWT signing key — generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# PostgreSQL credentials — use 32+ random characters
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password_32chars

# Admin dashboard login — use a password manager
ADMIN_EMAIL=admin@upi.ai
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password_20chars

# Redis — required for production, optional for local dev
REDIS_PASSWORD=CHANGE_ME_redis_password

# Grafana admin
GRAFANA_PASSWORD=CHANGE_ME_grafana_password

# ─── Optional: Override defaults if needed ────────────────────────────────────

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=upi_fraud
POSTGRES_USER=upi_user
POSTGRES_EXTERNAL_PORT=5432

# Redis
REDIS_URL=redis://:CHANGE_ME_redis_password@redis:6379
REDIS_EXTERNAL_PORT=6379

# Kafka / Redpanda
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000

# Celery
CELERY_BROKER_URL=redis://:CHANGE_ME_redis_password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:CHANGE_ME_redis_password@redis:6379/2

# Service ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
GRAFANA_PORT=3001
GRAFANA_USER=admin

# Frontend public URLs (must be accessible from browser)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_GRAFANA_URL=http://localhost:3001

# MLOps services
BACKEND_URL=http://backend:8000

# ─── ML Thresholds ────────────────────────────────────────────────────────────
MODEL_FRAUD_THRESHOLD=0.5
MODEL_REVIEW_THRESHOLD=0.3
DRIFT_DETECTION_WINDOW=500
DRIFT_THRESHOLD=0.1
INFERENCE_TIMEOUT_MS=80

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=60
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW=900

# ─── Feast ────────────────────────────────────────────────────────────────────
FEAST_REPO_PATH=/mlops/feast_repo/feature_repo

# ─── Production Security Checklist ───────────────────────────────────────────
# [ ] SECRET_KEY rotated (never reuse across envs)
# [ ] POSTGRES_PASSWORD is 32+ chars, random
# [ ] ADMIN_PASSWORD is 20+ chars, stored in password manager
# [ ] REDIS_PASSWORD set (never empty)
# [ ] GRAFANA_PASSWORD changed from default
# [ ] TLS termination added (nginx/Traefik)
# [ ] Secrets stored in Vault/AWS SSM/GCP Secret Manager
# [ ] This .env file never committed to git
